@model GymManagementSystem.Application.DTOs.Package.CreatePackageDto

@{
    ViewData["Title"] = "Create Package";
}

<h1>Create Package</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="DurationInDays" class="form-label"></label>
                <input asp-for="DurationInDays" class="form-control" type="number" />
                <span asp-validation-for="DurationInDays" class="text-danger"></span>
            </div>
            
            <div class="mb-3 form-check">
                <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                <label class="form-check-label" asp-for="IsActive">Is Active</label>
            </div>

            <div class="mb-3">
                <label asp-for="MaxMembers" class="form-label"></label>
                <input asp-for="MaxMembers" class="form-control" type="number" />
                <span asp-validation-for="MaxMembers" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>
