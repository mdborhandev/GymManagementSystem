@using Microsoft.AspNetCore.Identity
@using GymManagementSystem.Domain.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var roleName = "No Role";
    if (user != null)
    {
        var roles = await UserManager.GetRolesAsync(user);
        roleName = roles.FirstOrDefault() ?? "No Role";
    }
}

<div class="bg-dark border-end" id="sidebar-wrapper">
    <div class="sidebar-heading border-bottom text-white p-3">
        <div class="mb-1"><i class="fas fa-dumbbell me-2"></i> Gym SaaS</div>
        <div class="small text-muted"><i class="fas fa-user-circle me-1"></i> @user?.FirstName (@roleName)</div>
    </div>
    <div class="list-group list-group-flush">
        <a href="@Url.Action("Index", "Home")" class="list-group-item list-group-item-action list-group-item-light p-3 bg-dark text-white">
            <i class="fas fa-tachometer-alt me-2"></i> Dashboard
        </a>

        @if (User.IsInRole("SuperAdmin"))
        {
            <div class="bg-secondary text-white small px-3 py-2 text-uppercase fw-bold" style="font-size: 0.7rem;">Platform Admin</div>
            <a href="@Url.Action("Index", "Gym")" class="list-group-item list-group-item-action list-group-item-light p-3 bg-dark text-white">
                <i class="fas fa-building me-2"></i> Manage All Gyms
            </a>
        }

        @if (User.IsInRole("GymAdmin"))
        {
            <div class="bg-secondary text-white small px-3 py-2 text-uppercase fw-bold" style="font-size: 0.7rem;">Gym Manager</div>
            <a href="@Url.Action("Index", "Member")" class="list-group-item list-group-item-action list-group-item-light p-3 bg-dark text-white">
                <i class="fas fa-users me-2"></i> Members
            </a>
            <a href="@Url.Action("Index", "Package")" class="list-group-item list-group-item-action list-group-item-light p-3 bg-dark text-white">
                <i class="fas fa-box me-2"></i> Packages
            </a>
            <a href="@Url.Action("Index", "Staff")" class="list-group-item list-group-item-action list-group-item-light p-3 bg-dark text-white">
                <i class="fas fa-user-tie me-2"></i> Staff
            </a>
        }

        <div class="mt-auto">
            <form asp-action="Logout" asp-controller="Account" method="post" id="logoutForm" class="d-none"></form>
            <a href="javascript:document.getElementById('logoutForm').submit()" class="list-group-item list-group-item-action list-group-item-light p-3 bg-danger text-white border-0">
                <i class="fas fa-sign-out-alt me-2"></i> Logout
            </a>
        </div>
    </div>
</div>
