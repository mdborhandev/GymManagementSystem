@{
    ViewData["Title"] = "Members (AJAX)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Members</h1>
    <button type="button" class="btn btn-primary" onclick="openCreateModal()">
        <i class="fas fa-plus"></i> Add New Member
    </button>
</div>

<div id="member-table"></div>

<!-- Modal -->
<div class="modal fade" id="memberModal" tabindex="-1" aria-labelledby="memberModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="memberModalLabel">Member Form</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="memberForm">
                    <input type="hidden" id="memberId" name="id" />
                    <div class="row mb-3">
                        <div class="col-6">
                            <label for="firstName" class="form-label">First Name</label>
                            <input type="text" class="form-control" id="firstName" name="firstName" required>
                        </div>
                        <div class="col-6">
                            <label for="lastName" class="form-label">Last Name</label>
                            <input type="text" class="form-control" id="lastName" name="lastName" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email">
                    </div>
                    <div class="mb-3">
                        <label for="phone" class="form-label">Phone</label>
                        <input type="text" class="form-control" id="phone" name="phone" required>
                    </div>
                    <div class="mb-3">
                        <label for="packageId" class="form-label">Package</label>
                        <select id="packageId" name="packageId" class="form-control" required>
                            <option value="">-- Loading Packages --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="gender" class="form-label">Gender</label>
                        <select id="gender" name="gender" class="form-control">
                            <option value="0">Male</option>
                            <option value="1">Female</option>
                            <option value="2">Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="status" class="form-label">Status</label>
                        <select id="status" name="status" class="form-control">
                            <option value="0">Active</option>
                            <option value="1">Inactive</option>
                            <option value="2">Suspended</option>
                            <option value="3">Expired</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveMember()">Save changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var table;
    $(document).ready(function () {
        loadPackages();
        
        table = new Tabulator("#member-table", {
            ajaxURL: "/Member/GetAll",
            layout: "fitColumns",
            responsiveLayout: "collapse",
            pagination: "local",
            paginationSize: 10,
            columns: [
                { title: "Full Name", field: "fullName", sorter: "string", headerFilter: "input" },
                { title: "Email", field: "email", sorter: "string" },
                { title: "Phone", field: "phone", sorter: "string" },
                { title: "Package", field: "packageName", sorter: "string" },
                { title: "Status", field: "status", hozAlign: "center", formatter: function(cell) {
                    var val = cell.getValue();
                    var cls = val === "Active" ? "success" : "secondary";
                    return `<span class='badge bg-${cls}'>${val}</span>`;
                }},
                {
                    title: "Actions", formatter: function (cell, formatterParams, onRendered) {
                        var id = cell.getData().id;
                        return `<button class='btn btn-sm btn-warning me-2' onclick='openEditModal("${id}")'><i class='fas fa-edit'></i></button>` +
                               `<button class='btn btn-sm btn-danger' onclick='deleteMember("${id}")'><i class='fas fa-trash'></i></button>`;
                    }, width: 150, hozAlign: "center", headerSort: false
                }
            ],
        });
    });

    function loadPackages() {
        $.get('/Member/GetPackageList', function (data) {
            var options = '<option value="">-- Select Package --</option>';
            data.forEach(function (p) {
                options += `<option value="${p.id}">${p.name}</option>`;
            });
            $('#packageId').html(options);
        });
    }

    function openCreateModal() {
        $('#memberForm')[0].reset();
        $('#memberId').val('');
        $('#memberModalLabel').text('Add New Member');
        $('#memberModal').modal('show');
    }

    function openEditModal(id) {
        $.get('/Member/GetById', { id: id }, function (data) {
            // Need to handle field mapping as MemberResponse properties might slightly differ from form
            $('#memberId').val(data.id);
            // Splitting name is tricky since we only have FullName in Response
            // Let's assume for this demo we populated firstName/lastName in the JSON as well
            // Or better: update MemberResponse to include them.
            $('#firstName').val(data.firstName || data.fullName.split(' ')[0]);
            $('#lastName').val(data.lastName || data.fullName.split(' ')[1]);
            $('#email').val(data.email);
            $('#phone').val(data.phone);
            $('#packageId').val(data.packageId);
            $('#status').val(data.statusEnumValue); // Assuming we added enum value to JSON
            $('#memberModalLabel').text('Edit Member');
            $('#memberModal').modal('show');
        });
    }

    function saveMember() {
        var id = $('#memberId').val();
        var url = id ? '/Member/Edit' : '/Member/Create';
        var data = {
            id: id || undefined,
            firstName: $('#firstName').val(),
            lastName: $('#lastName').val(),
            email: $('#email').val(),
            phone: $('#phone').val(),
            packageId: $('#packageId').val(),
            gender: parseInt($('#gender').val()),
            status: parseInt($('#status').val()),
            dateOfBirth: "1990-01-01" // Placeholder or use a datepicker
        };

        $.ajax({
            url: url,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (response) {
                if (response.success) {
                    $('#memberModal').modal('hide');
                    table.setData();
                } else {
                    alert(response.message || "Error saving member");
                }
            }
        });
    }

    function deleteMember(id) {
        if (confirm("Are you sure you want to delete this member?")) {
            $.post('/Member/Delete', { id: id }, function (response) {
                if (response.success) {
                    table.setData();
                } else {
                    alert("Error deleting member");
                }
            });
        }
    }
</script>
}
