@{
    ViewData["Title"] = "Gyms (AJAX)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Gyms</h1>
    <button type="button" class="btn btn-primary" onclick="openCreateModal()">
        <i class="fas fa-plus"></i> Add New Gym
    </button>
</div>

<div id="gym-table"></div>

<!-- Modal for Create/Edit -->
<div class="modal fade" id="gymModal" tabindex="-1" aria-labelledby="gymModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="gymModalLabel">Gym Form</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="gymForm">
                    <input type="hidden" id="gymId" name="id" />
                    <div class="mb-3">
                        <label for="name" class="form-label">Name</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="address" class="form-label">Address</label>
                        <input type="text" class="form-control" id="address" name="address">
                    </div>
                    <div class="mb-3">
                        <label for="phone" class="form-label">Phone</label>
                        <input type="text" class="form-control" id="phone" name="phone">
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveGym()">Save changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var table;
    $(document).ready(function () {
        // Initialize Tabulator
        table = new Tabulator("#gym-table", {
            ajaxURL: "/Gym/GetAll", // Fetch data via AJAX
            layout: "fitColumns",
            responsiveLayout: "collapse",
            pagination: "local",
            paginationSize: 10,
            columns: [
                { title: "Name", field: "name", sorter: "string", headerFilter: "input" },
                { title: "Address", field: "address", sorter: "string" },
                { title: "Phone", field: "phone", sorter: "string" },
                { title: "Email", field: "email", sorter: "string" },
                {
                    title: "Actions", formatter: function (cell, formatterParams, onRendered) {
                        var id = cell.getData().id;
                        return `<button class='btn btn-sm btn-warning me-2' onclick='openEditModal("${id}")'><i class='fas fa-edit'></i></button>` +
                               `<button class='btn btn-sm btn-danger' onclick='deleteGym("${id}")'><i class='fas fa-trash'></i></button>`;
                    }, width: 150, hozAlign: "center", headerSort: false
                }
            ],
        });
    });

    function openCreateModal() {
        $('#gymForm')[0].reset();
        $('#gymId').val('');
        $('#gymModalLabel').text('Add New Gym');
        $('#gymModal').modal('show');
    }

    function openEditModal(id) {
        $.get('/Gym/GetById', { id: id }, function (data) {
            $('#gymId').val(data.id);
            $('#name').val(data.name);
            $('#address').val(data.address);
            $('#phone').val(data.phone);
            $('#email').val(data.email);
            $('#gymModalLabel').text('Edit Gym');
            $('#gymModal').modal('show');
        });
    }

    function saveGym() {
        var id = $('#gymId').val();
        var url = id ? '/Gym/Edit' : '/Gym/Create';
        var data = {
            id: id || undefined,
            name: $('#name').val(),
            address: $('#address').val(),
            phone: $('#phone').val(),
            email: $('#email').val()
        };

        $.ajax({
            url: url,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (response) {
                if (response.success) {
                    $('#gymModal').modal('hide');
                    table.setData(); // Refresh Tabulator table
                } else {
                    alert(response.message || "Error saving gym");
                }
            }
        });
    }

    function deleteGym(id) {
        if (confirm("Are you sure you want to delete this gym?")) {
            $.post('/Gym/Delete', { id: id }, function (response) {
                if (response.success) {
                    table.setData();
                } else {
                    alert("Error deleting gym");
                }
            });
        }
    }
</script>
}
